<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="KcpProbe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KcpProbe"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="KCP Tester">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="MainContentRow" Height="*" MinHeight="100"/>
            <RowDefinition Height="6"/>
            <RowDefinition x:Name="LogPanelRow" Height="220" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,0,0">
                <Image Source="Assets/app.png" Width="16" Height="16"/>
                <TextBlock Text="KCP Tester" VerticalAlignment="Center"/>
                <TextBlock x:Name="AppVersionText" Text="v..." Foreground="Gray" FontSize="10" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                <!-- Network Badge -->
                <Ellipse Width="8" Height="8" Fill="{Binding Status.StatusColor}" ToolTipService.ToolTip="{Binding Status.ConnectionStatus}" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
            
            <!-- Middle: Environment & Profile -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ComboBox PlaceholderText="Environment" SelectedIndex="0" Width="120" Height="28" Padding="8,4,0,0" FontSize="12">
                     <ComboBoxItem Content="Localhost"/>
                     <ComboBoxItem Content="Dev"/>
                     <ComboBoxItem Content="Staging"/>
                </ComboBox>
                
                <ComboBox PlaceholderText="Profile" SelectedIndex="0" Width="140" Height="28" Padding="8,4,0,0" FontSize="12">
                     <ComboBoxItem Content="Default"/>
                     <ComboBoxItem Content="Low Latency"/>
                     <ComboBoxItem Content="High Loss"/>
                </ComboBox>
            </StackPanel>

            <!-- Right: Actions -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="5" Margin="0,0,8,0">
                 <!-- Theme Toggle -->
                 <Button x:Name="ThemeButton" Click="ThemeButton_Click" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Toggle Theme">
                     <SymbolIcon x:Name="ThemeIcon"/>
                 </Button>
                 
                 <!-- Settings -->
                 <Button Click="SettingsButton_Click" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Settings">
                     <SymbolIcon Symbol="Setting"/>
                 </Button>

                 <!-- Help -->
                 <Button Click="HelpButton_Click" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Help">
                     <SymbolIcon Symbol="Help"/>
                 </Button>

                 <ToggleButton x:Name="PinTopButton" Click="PinTopButton_Click" VerticalAlignment="Stretch" Width="30" BorderThickness="0" Background="Transparent" ToolTipService.ToolTip="Always on Top">
                    <SymbolIcon x:Name="PinTopIcon" Symbol="Pin" Margin="0,-3,0,0"/>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Header: Connection Config -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <TextBox Header="Server IP" Text="{Binding ServerIp, Mode=TwoWay}" Width="150"/>
                    <NumberBox Header="Port" Value="{Binding ServerPort, Mode=TwoWay}" Width="100"/>
                    <NumberBox Header="Conv ID" Value="{Binding ConvId, Mode=TwoWay}" Width="100"/>
                    <Button Content="{Binding Status.ConnectButtonText}" Command="{Binding ToggleConnectCommand}" VerticalAlignment="Bottom"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Bottom" Margin="20,0,0,5">
                    <TextBlock Text="{Binding Status.StatsInfo}" Foreground="LightGreen" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" VerticalAlignment="Bottom" Margin="0,0,10,5">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Status:" Foreground="Gray"/>
                        <TextBlock Text="{Binding Status.ConnectionStatus}" Foreground="{Binding Status.StatusColor}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Health:" Foreground="Gray"/>
                        <TextBlock Text="{Binding Status.HealthStatus}" Foreground="{Binding Status.HealthColor}" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <Expander Header="Advanced KCP Settings" HorizontalAlignment="Stretch" IsExpanded="False" Margin="10,0,10,10">
                <StackPanel Orientation="Horizontal" Spacing="20" Padding="10">
                    <CheckBox Content="NoDelay" IsChecked="{Binding Config.NoDelay, Mode=TwoWay}"/>
                    <NumberBox Header="Interval (ms)" Value="{Binding Config.Interval, Mode=TwoWay}" Width="100"/>
                    <NumberBox Header="Resend" Value="{Binding Config.Resend, Mode=TwoWay}" Width="80"/>
                    <CheckBox Content="NC (Flow Control)" IsChecked="{Binding Config.Nc, Mode=TwoWay}"/>
                    <NumberBox Header="SndWnd" Value="{Binding Config.SndWnd, Mode=TwoWay}" Width="80"/>
                    <NumberBox Header="RcvWnd" Value="{Binding Config.RcvWnd, Mode=TwoWay}" Width="80"/>
                </StackPanel>
            </Expander>
        </StackPanel>

        <!-- Content: Tabs -->
        <NavigationView Grid.Row="2" PaneDisplayMode="Top" IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <!-- <NavigationViewItem Content="Interface Test" Tag="Interface"/>
                <NavigationViewItem Content="Stress Test" Tag="Stress"/> -->
            </NavigationView.MenuItems>
            
            <!-- Simplified Content for now without navigation logic overhead -->
            <Grid Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Interface Test -->
                    <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
                        <TextBlock Text="Interface Test" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBox Header="Ping Content" Text="{Binding PingContent, Mode=TwoWay}"/>
                        <Button Content="Send Ping" Command="{Binding SendPingCommand}"/>

                        <!-- RPC Section -->
                        <Border Margin="0,20,0,0" BorderThickness="0,1,0,0" BorderBrush="Gray" Padding="0,10,0,0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="RPC Test" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBox Header="Method" Text="{Binding ApiMethod, Mode=TwoWay}"/>
                                <TextBox Header="Params (JSON)" Text="{Binding ApiParams, Mode=TwoWay}" Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>
                                <Button Content="Call API" Command="{Binding SendRpcCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Splitter -->
                    <local:ResizeHandleBorder Grid.Column="1" Width="5" Cursor="SizeWestEast" Background="#404040" Margin="0,0,10,0"
                        PointerPressed="Splitter_PointerPressed" PointerMoved="Splitter_PointerMoved" PointerReleased="Splitter_PointerReleased" PointerCaptureLost="Splitter_PointerCaptureLost"/>

                    <!-- Right: Stress Test & Bots & Monitor -->
                    <StackPanel Grid.Column="2" Spacing="10" Margin="0,0,0,0" Padding="10,0,0,0">
                        <TextBlock Text="Stress Test" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Simple Stress Test (100 QPS)"/>
                        <Button Content="{Binding StressButtonText}" Command="{Binding ToggleStressCommand}"/>

                        <TextBlock Text="Bot Swarm" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                             <NumberBox Header="Count" Value="{Binding Bot.BotCount, Mode=TwoWay}" Width="100"/>
                             <Button Content="{Binding Bot.BotButtonText}" Command="{Binding Bot.ToggleBotsCommand}" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        
                        <TextBlock Text="RTT Monitor (ms)" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,10,0,0"/>
                        <Border BorderBrush="#303030" BorderThickness="1" Height="100" Background="#101010">
                            <Grid>
                                <Canvas x:Name="RttCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="RttCanvas_SizeChanged"/>
                                <TextBlock x:Name="CurrentRttText" Text="-- ms" Foreground="LightGreen" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="5" FontSize="12"/>
                                <TextBlock Text="0 ms" Foreground="Gray" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10"/>
                                <TextBlock Text="100+ ms" Foreground="Gray" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10"/>
                            </Grid>
                        </Border>

                        <Border Margin="0,10,0,0" BorderThickness="0,1,0,0" BorderBrush="Gray" Padding="0,10,0,0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Test Management" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <CheckBox Content="Skip server startup" IsChecked="{Binding SkipServerForRegression, Mode=TwoWay}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="{Binding RunRegressionButtonText}" Command="{Binding RunRegressionCommand}"/>
                                    <Button Content="Stop" Command="{Binding StopRegressionCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
        </NavigationView>

        <local:ResizeHandleBorder
            x:Name="LogResizeHandle"
            Grid.Row="3"
            Height="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#404040"
            PointerPressed="LogResizeHandle_PointerPressed"
            PointerMoved="LogResizeHandle_PointerMoved"
            PointerReleased="LogResizeHandle_PointerReleased"
            PointerCaptureLost="LogResizeHandle_PointerCaptureLost"/>

        <!-- Footer: Logs -->
        <Grid Grid.Row="4" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="5,2,5,2">
                <TextBox PlaceholderText="Search logs..." Text="{Binding FilterKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" VerticalAlignment="Center"/>
                <CheckBox Content="Errors Only" IsChecked="{Binding ShowErrorsOnly, Mode=TwoWay}" VerticalAlignment="Center" Foreground="White"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8" Margin="8,2,8,2">
                <Button Content="Copy Selected" Click="CopySelectedLogs_Click" FontSize="11"/>
                <Button Content="Copy All" Click="CopyAllLogs_Click" FontSize="11"/>
                <Button Content="Clear" Command="{Binding ClearLogsCommand}" FontSize="11"/>
            </StackPanel>

            <ListView
                Grid.Row="1"
                x:Name="LogsListView"
                ItemsSource="{Binding LogsView}"
                FontFamily="Consolas"
                SelectionMode="Extended">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                         <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding FormattedTime}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding Message}" Foreground="{Binding Color}" FontSize="12" IsTextSelectionEnabled="True"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
